{
  "name": "code-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k -s first \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron:start\"",
    "dev:renderer": "vite",
    "dev:electron:watch": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron:start": "wait-on tcp:5173 && electron .",
    "build:electron": "tsc -p electron/tsconfig.json",
    "typecheck": "tsc -b && tsc -p electron/tsconfig.json --noEmit",
    "build": "npm run build:electron && tsc -b && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint src electron vite.config.ts",
    "test": "npm run build:electron && vitest run",
    "test:watch": "vitest",
    "test:electron-runtime": "electron scripts/check-electron-runtime.cjs",
    "verify:full": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run test:electron-runtime && npm run build",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@astral-sh/ruff-wasm-nodejs": "^0.15.20",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@tailwindcss/vite": "^4.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "eslint": "^10.6.0",
    "highlight.js": "^11.11.1",
    "html-validate": "^11.0.0",
    "jsonc-parser": "^3.3.1",
    "markdownlint": "^0.41.0",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^6.1.200",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stylelint": "^17.14.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.5.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "prettier": "3.9.4",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "main": "dist-electron/main.cjs"
}
