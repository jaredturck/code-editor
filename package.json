{
  "name": "code-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k -s first \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron:start\"",
    "dev:renderer": "vite",
    "dev:electron:watch": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron:start": "wait-on tcp:5173 && electron .",
    "build:electron": "tsc -p electron/tsconfig.json",
    "typecheck": "tsc -b && tsc -p electron/tsconfig.json --noEmit",
    "build": "npm run build:electron && tsc -b && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint src electron vite.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@tailwindcss/vite": "^4.3.2",
    "codemirror": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.5.1",
    "oxlint": "^1.69.0",
    "prettier": "3.9.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  },
  "main": "dist-electron/main.cjs"
}
